{
  "project": "hydra-kernels-improvements",
  "version": "1.0",
  "created": "2026-04-10",
  "execution_mode": {
    "full_run": false
  },
  "tracks": {
    "track_a_hyperparam_sensitivity": {
      "enabled": true,
      "description": "Hydra hyperparameter sensitivity on k and g",
      "k_values": [4, 8],
      "g_values": [32, 64],
      "resamples": 1,
      "max_local_datasets": 3,
      "full_k_values": [4, 8, 16],
      "full_g_values": [32, 64, 128],
      "full_resamples": 3,
      "max_full_datasets": 50
    },
    "track_b_variant_analysis": {
      "enabled": true,
      "description": "Analyze existing Hydra+ROCKET-family results vs Hydra baseline",
      "resamples": 30,
      "source_files": {
        "hydra": "results/results_ucr112_hydra.csv",
        "variants": "results/results_ucr112_variants.csv"
      }
    },
    "track_c_timing_quality": {
      "enabled": true,
      "description": "Split transform/fit/predict timing and assess trade-offs",
      "resamples": 3,
      "max_local_datasets": 3,
      "full_resamples": 10,
      "max_full_datasets": 10
    }
  },
  "dataset_subsets": {
    "local_pilot": ["GunPoint", "Adiac", "ElectricDevices"],
    "full_run_recommended": [
      "ACSF1",
      "Adiac",
      "ArrowHead",
      "BME",
      "Beef",
      "BeetleFly",
      "BirdChicken",
      "CBF",
      "Car",
      "Chinatown",
      "ChlorineConcentration",
      "CinCECGTorso",
      "Coffee",
      "Computers",
      "CricketX",
      "CricketY",
      "CricketZ",
      "Crop",
      "DiatomSizeReduction",
      "DistalPhalanxOutlineAgeGroup",
      "DistalPhalanxOutlineCorrect",
      "DistalPhalanxTW",
      "ECG200",
      "ECG5000",
      "ECGFiveDays",
      "EOGHorizontalSignal",
      "EOGVerticalSignal",
      "Earthquakes",
      "ElectricDevices",
      "EthanolLevel",
      "FaceAll",
      "FaceFour",
      "FacesUCR",
      "FiftyWords",
      "Fish",
      "FordA",
      "FordB",
      "FreezerRegularTrain",
      "FreezerSmallTrain",
      "GunPoint",
      "GunPointAgeSpan",
      "GunPointMaleVersusFemale",
      "GunPointOldVersusYoung",
      "Ham",
      "HandOutlines",
      "Haptics",
      "Herring",
      "HouseTwenty",
      "InlineSkate",
      "InsectEPGRegularTrain"
    ]
  },
  "runtime_policy": {
    "local_machine": {
      "role": "validation_only",
      "max_hours": 5,
      "notes": "Run smoke and pilot only on 16GB RAM laptop."
    },
    "full_training": {
      "role": "full_compute",
      "notes": "Run full experiment matrix on Mac M4 Pro."
    }
  },
  "output_policy": {
    "raw_root": "improvements/outputs",
    "analysis_root": "improvements/analysis",
    "master_summary": "improvements/analysis/improvements_master_summary.csv"
  }
}
